# FetchTranscript.com API key (starts with yt_)
FETCHTRANSCRIPT_API_KEY=yt_your_key_here

# Anthropic API key for Claude translation
ANTHROPIC_API_KEY=sk-ant-api03-...

# ai33 TTS (ElevenLabs v3, voice Lars). Get base URL from ai33 API docs.
AI33_API_KEY=your_ai33_key_here
AI33_BASE_URL=https://api.ai33.pro
AI33_VOICE_ID=raYPS0b2ZPlIzZWkcD0G
AI33_MODEL=eleven_multilingual_v2

# ElevenLabs fallback (when ai33 fails/slow). Model fixed to eleven_multilingual_v2.
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=z71EjgDq5DjMmSU6Azn9

# Trello integration (optional). Needed for "Create Trello card" module.
# Get API key/token from Trello developer settings and IDs from board/card URLs.
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_token_here
TRELLO_BOARD_ID=qEVZULw5                  # va-board (from https://trello.com/b/qEVZULw5/va-board)
TRELLO_TEMPLATE_CARD_ID=oH2grIYa          # template card (from https://trello.com/c/oH2grIYa)

# Google Drive integration (optional). Used for folder structure + voice-over upload.
# Path is relative to backend/ or absolute on your machine.
GOOGLE_SERVICE_ACCOUNT_FILE=backend/credentials/google-service-account.json
# Shared Drive root for Sentence Match tool:
# https://drive.google.com/drive/folders/1DBTD3FlaNZDQLq-FcTk_DkHsQAud76ve
DRIVE_ROOT_FOLDER_ID=1DBTD3FlaNZDQLq-FcTk_DkHsQAud76ve

# Sources sheet (optional). One SRC ID per channel; key = YouTube channel ID (or fallback video URL).
# Create a Google Sheet, share it with the service account email (Editor). Sheet ID = URL path:
# https://docs.google.com/spreadsheets/d/<SOURCES_SHEET_ID>/edit
SOURCES_SHEET_ID=
# Tab name inside the spreadsheet (default: Sheet1)
# SOURCES_SHEET_TAB=Sheet1
# YouTube Data API key (optional but recommended). Enables one ID per channel; without it we key by video URL.
# Create in Google Cloud Console → APIs & Services → Credentials. Enable YouTube Data API v3.
YOUTUBE_API_KEY=
